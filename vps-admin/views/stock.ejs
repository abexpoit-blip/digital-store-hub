<%- include('partials/header', { title: 'Stock', msg, currentPath }) %>

<h1 class="text-2xl font-bold mb-1">📦 Stock Management</h1>
<p class="text-slate-400 text-sm mb-2">Bot এর <code class="bg-slate-800 px-1.5 py-0.5 rounded">/add</code> command এর সাথে 100% match — শুধু allowed categories ব্যবহার হবে।</p>

<!-- Allowed categories info -->
<div class="bg-cyan-950/40 border border-cyan-800/50 rounded-lg p-3 mb-5 text-xs">
  <div class="text-cyan-300 font-semibold mb-1">✅ Allowed Categories (bot recognize করে):</div>
  <div class="flex gap-2 flex-wrap">
    <% allowedCategories.forEach(function(c){ %>
      <span class="bg-cyan-900/60 border border-cyan-700 text-cyan-200 px-2 py-0.5 rounded font-mono"><%= c %></span>
    <% }) %>
  </div>
  <div class="text-slate-400 mt-2">
    📝 Format: <code class="bg-slate-800 px-1 rounded">UID PASS COOKIES</code> (space-separated)
    &nbsp;•&nbsp; Multi-upload separator: <code class="bg-slate-800 px-1 rounded">###</code>
  </div>
</div>

<% if (preview && preview.length) { %>
  <div class="bg-amber-900/20 border border-amber-700/50 rounded-xl p-5 mb-6">
    <div class="text-sm font-semibold text-amber-200 mb-2">
      ⚠ Preview — <%= previewCount %> unique items ready
      <% if (typeof duplicates !== 'undefined' && duplicates > 0) { %>
        <span class="text-rose-300">(<%= duplicates %> duplicate skipped)</span>
      <% } %>
    </div>
    <div class="flex flex-wrap gap-2 mb-3">
      <% Object.keys(previewByCat).forEach(function(cat){ %>
        <span class="bg-slate-800 border border-slate-700 px-2 py-1 rounded text-xs">
          <span class="text-cyan-400 font-semibold"><%= cat %></span>
          <span class="text-emerald-400 ml-1">+<%= previewByCat[cat] %></span>
        </span>
      <% }) %>
    </div>
    <div class="max-h-64 overflow-y-auto bg-slate-950 rounded p-2 mb-3">
      <table class="w-full text-xs">
        <thead><tr><th>#</th><th>Category</th><th>Data (UID PASS COOKIES)</th></tr></thead>
        <tbody>
          <% preview.forEach(function(p, i){ %>
            <tr><td class="text-slate-500"><%= i+1 %></td><td class="text-cyan-400"><%= p.category %></td><td class="font-mono text-slate-300"><%= p.data.length>100 ? p.data.slice(0,100)+'...' : p.data %></td></tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="flex gap-2">
      <form method="post" action="/stock/confirm"><button class="bg-emerald-600 hover:bg-emerald-500 px-4 py-2 rounded text-sm font-semibold">✅ Confirm Insert (<%= previewCount %>)</button></form>
      <form method="post" action="/stock/cancel"><button class="bg-slate-700 hover:bg-slate-600 px-4 py-2 rounded text-sm">Cancel</button></form>
    </div>
  </div>
<% } %>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
  <!-- EXCEL UPLOAD -->
  <form method="post" action="/stock/upload" enctype="multipart/form-data"
        class="bg-slate-900 border border-slate-800 p-5 rounded-xl">
    <div class="flex items-center justify-between mb-3">
      <div class="text-sm font-semibold">📤 Excel Upload</div>
      <a href="/stock/sample" class="text-xs text-cyan-400 hover:underline">⬇ Download sample</a>
    </div>

    <p class="text-xs text-slate-400 mb-3">
      Excel format: <strong>3 columns</strong> — <code class="bg-slate-800 px-1 rounded">UID</code> |
      <code class="bg-slate-800 px-1 rounded">PASS</code> | <code class="bg-slate-800 px-1 rounded">COOKIES</code>।
      প্রতি row = একটা stock item। Header row optional।
    </p>

    <label class="text-xs text-slate-400 block mb-1">Category:</label>
    <select name="category" required class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm mb-3">
      <option value="">— Select category —</option>
      <% allowedCategories.forEach(function(c){ %>
        <option value="<%= c %>"><%= c %></option>
      <% }) %>
    </select>

    <input type="file" name="file" accept=".xlsx,.xls" required
      class="w-full text-sm text-slate-300 file:mr-3 file:bg-cyan-600 file:text-white file:border-0 file:px-3 file:py-1.5 file:rounded mb-3"/>
    <button class="w-full bg-cyan-600 hover:bg-cyan-500 py-2 rounded text-sm font-semibold">Upload & Preview</button>
  </form>

  <!-- MANUAL TEXTAREA -->
  <form method="post" action="/stock/manual"
        class="bg-slate-900 border border-slate-800 p-5 rounded-xl">
    <div class="text-sm font-semibold mb-3">✍ Manual Add (newline বা <code class="bg-slate-800 px-1 rounded">###</code> separator)</div>

    <label class="text-xs text-slate-400 block mb-1">Category:</label>
    <select name="category" required class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm mb-3">
      <option value="">— Select category —</option>
      <% allowedCategories.forEach(function(c){ %>
        <option value="<%= c %>"><%= c %></option>
      <% }) %>
    </select>

    <textarea name="data" required rows="8"
      placeholder="100011382171459 Sabbir@25 datr=ODPsaT...; c_user=100011382171459; xs=33%3A...&#10;100011382171460 OtherPass cookies-here..."
      class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-xs font-mono mb-3"></textarea>

    <div class="text-xs text-slate-500 mb-3">
      💡 প্রতি লাইনে: <code class="bg-slate-800 px-1 rounded">UID PASS COOKIES</code> (space-separated)।
      একসাথে অনেক item হলে <code class="bg-slate-800 px-1 rounded">###</code> দিয়ে separate করুন।
    </div>
    <button class="w-full bg-cyan-600 hover:bg-cyan-500 py-2 rounded text-sm font-semibold">Add Stock</button>
  </form>
</div>

<!-- ===== QUICK SELL / GENERATE EXCEL ===== -->
<form method="post" action="/stock/sell"
      class="bg-gradient-to-br from-emerald-950/40 to-slate-900 border border-emerald-800/60 p-5 rounded-xl mb-6">
  <div class="mb-3">
    <div class="text-sm font-semibold text-emerald-300">🛒 Quick Sell — Generate Excel & Auto-Cut Stock</div>
    <div class="text-xs text-slate-400 mt-0.5">Category + qty দিন → N টা ID Excel আকারে download হবে এবং stock থেকে auto cut হবে।</div>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
    <div>
      <label class="text-xs text-slate-400 block mb-1">Category</label>
      <select name="category" required class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm">
        <option value="">— Select —</option>
        <% allowedCategories.forEach(function(c){ %>
          <option value="<%= c %>"><%= c %> (<%= (byCategory.find(function(x){return x.category===c})||{}).c || 0 %> available)</option>
        <% }) %>
      </select>
    </div>
    <div>
      <label class="text-xs text-slate-400 block mb-1">Quantity</label>
      <input type="number" name="qty" min="1" required placeholder="5"
        class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm"/>
    </div>
    <div>
      <label class="text-xs text-slate-400 block mb-1">Buyer / Note (optional)</label>
      <input type="text" name="buyer" placeholder="username or note"
        class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm"/>
    </div>
    <div>
      <label class="text-xs text-slate-400 block mb-1">Price/unit ৳ (optional)</label>
      <input type="number" name="price" min="0" step="0.01" placeholder="0"
        class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm"/>
    </div>
  </div>
  <button class="mt-3 w-full bg-emerald-600 hover:bg-emerald-500 py-2.5 rounded text-sm font-semibold"
          onclick="return confirm('Stock থেকে cut হবে — proceed?');">
    ⬇ Generate Excel & Deduct Stock
  </button>
</form>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
    <div class="px-4 py-3 border-b border-slate-800 text-sm font-semibold flex justify-between">
      <span>📊 Stock by Category</span>
      <span class="text-xs text-slate-400"><%= byCategory.length %> categories</span>
    </div>
    <table class="w-full text-sm">
      <thead><tr><th>Category</th><th>Count</th><th></th></tr></thead>
      <tbody>
        <% byCategory.forEach(function(c){ %>
          <tr>
            <td class="font-semibold <%= c.unknown ? 'text-amber-400' : 'text-cyan-400' %>">
              <%= c.category %>
              <% if (c.unknown) { %><span class="text-xs ml-1" title="Bot এ unknown category">⚠️</span><% } %>
            </td>
            <td class="font-mono <%= c.c < 5 ? 'text-rose-400' : 'text-emerald-400' %>"><%= c.c %></td>
            <td>
              <% if (c.c > 0) { %>
                <form method="post" action="/stock/clear/<%= encodeURIComponent(c.category) %>"
                  onsubmit="return confirm('Sure delete all <%= c.c %> items from <%= c.category %>?');">
                  <button class="text-xs text-rose-400 hover:text-rose-300">Clear all</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
    <div class="px-4 py-3 border-b border-slate-800 text-sm font-semibold">📜 Recent Stock</div>
    <div class="max-h-96 overflow-y-auto">
      <table class="w-full text-xs">
        <thead><tr><th>ID</th><th>Cat</th><th>Preview</th></tr></thead>
        <tbody>
          <% recent.forEach(function(r){ %>
            <tr><td class="text-slate-500">#<%= r.id %></td><td class="text-cyan-400"><%= r.category %></td><td class="font-mono text-slate-400"><%= r.preview %></td></tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
