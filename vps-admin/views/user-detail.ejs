<%- include('partials/header', { title: 'User Detail', msg, currentPath }) %>

<a href="/users" class="text-sm text-slate-400 hover:text-white">← Back to users</a>

<div class="flex items-center justify-between mt-3 mb-6">
  <div>
    <h1 class="text-2xl font-bold"><%= user.username || 'Unknown' %></h1>
    <div class="text-sm text-slate-400 font-mono">ID: <%= user.user_id %></div>
  </div>
  <div class="text-right">
    <div class="text-3xl font-bold text-emerald-400"><%= (user.balance||0).toLocaleString() %>৳</div>
    <div class="text-xs text-slate-500">Current balance</div>
  </div>
</div>

<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl">
    <div class="text-xs text-slate-400">Total Spent</div>
    <div class="text-xl font-bold mt-1"><%= totalSpent.toLocaleString() %>৳</div>
  </div>
  <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl">
    <div class="text-xs text-slate-400">Total Deposited</div>
    <div class="text-xl font-bold mt-1 text-cyan-400"><%= totalDeposited.toLocaleString() %>৳</div>
  </div>
  <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl">
    <div class="text-xs text-slate-400">Orders</div>
    <div class="text-xl font-bold mt-1"><%= sales.length %></div>
  </div>
  <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl">
    <div class="text-xs text-slate-400">Status</div>
    <div class="text-xl font-bold mt-1 <%= user.is_banned ? 'text-rose-400' : 'text-emerald-400' %>">
      <%= user.is_banned ? 'BANNED' : 'Active' %>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
  <form method="post" action="/users/<%= user.user_id %>/balance"
        class="bg-slate-900 border border-slate-800 p-5 rounded-xl">
    <div class="text-sm font-semibold mb-3">💰 Adjust Balance</div>
    <input name="delta" type="number" required placeholder="+100 বা -50"
      class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm mb-2"/>
    <input name="reason" placeholder="Reason (audit log এ যাবে)" required
      class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm mb-3"/>
    <button class="w-full bg-cyan-600 hover:bg-cyan-500 py-2 rounded text-sm font-semibold">Apply</button>
    <p class="text-xs text-slate-500 mt-2">Positive = add, negative = deduct</p>
  </form>

  <form method="post" action="/users/<%= user.user_id %>/ban"
        class="bg-slate-900 border border-slate-800 p-5 rounded-xl">
    <div class="text-sm font-semibold mb-3"><%= user.is_banned ? '✅ Unban User' : '🚫 Ban User' %></div>
    <input type="hidden" name="banned" value="<%= user.is_banned ? '0' : '1' %>"/>
    <p class="text-sm text-slate-400 mb-3">
      <% if (user.is_banned) { %>এই user আবার bot ব্যবহার করতে পারবে।<% } else { %>এই user bot এ access হারাবে।<% } %>
    </p>
    <button class="w-full <%= user.is_banned ? 'bg-emerald-600 hover:bg-emerald-500' : 'bg-rose-600 hover:bg-rose-500' %> py-2 rounded text-sm font-semibold">
      <%= user.is_banned ? 'Unban' : 'Ban' %>
    </button>
  </form>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
    <div class="px-4 py-3 border-b border-slate-800 text-sm font-semibold">💸 Deposit History</div>
    <table class="w-full text-xs">
      <thead><tr><th>Amount</th><th>Status</th><th>Date</th></tr></thead>
      <tbody>
        <% if (!deposits.length) { %><tr><td colspan="3" class="text-center text-slate-500 py-4">No deposits</td></tr><% } %>
        <% deposits.forEach(function(d){ %>
          <tr>
            <td><%= d.amount %>৳</td>
            <td>
              <span class="px-2 py-0.5 rounded text-xs
                <%= d.status==='approved'?'bg-emerald-700/40 text-emerald-300':d.status==='pending'?'bg-amber-700/40 text-amber-300':'bg-rose-700/40 text-rose-300' %>">
                <%= d.status %>
              </span>
            </td>
            <td class="text-slate-400"><%= d.date || '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
    <div class="px-4 py-3 border-b border-slate-800 text-sm font-semibold">📥 Order History</div>
    <table class="w-full text-xs">
      <thead><tr><th>Category</th><th>Qty</th><th>Total</th><th>Date</th></tr></thead>
      <tbody>
        <% if (!sales.length) { %><tr><td colspan="4" class="text-center text-slate-500 py-4">No orders</td></tr><% } %>
        <% sales.forEach(function(s){ %>
          <tr>
            <td><%= s.category %></td>
            <td><%= s.qty %></td>
            <td class="text-emerald-400"><%= s.total %>৳</td>
            <td class="text-slate-400"><%= s.date %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('partials/footer') %>
