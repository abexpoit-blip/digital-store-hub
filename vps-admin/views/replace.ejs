<%- include('partials/header', { title: 'Replace Requests', msg, currentPath }) %>

<h1 class="text-2xl font-bold mb-4">🔄 Replace Requests</h1>

<div class="flex gap-2 mb-4">
  <a href="/replace?status=pending" class="px-4 py-2 rounded text-sm <%= status==='pending'?'bg-amber-600 text-white':'bg-slate-800 text-slate-300' %>">
    Pending (<%= counts.pending %>)
  </a>
  <a href="/replace?status=collected" class="px-4 py-2 rounded text-sm <%= status==='collected'?'bg-emerald-600 text-white':'bg-slate-800 text-slate-300' %>">
    Collected (<%= counts.collected %>)
  </a>
</div>

<div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
  <table class="w-full text-sm">
    <thead><tr><th>ID</th><th>User</th><th>Category</th><th>Old Data</th><th>Reason</th><th>Submitted</th><th>Action</th></tr></thead>
    <tbody>
      <% if (!rows.length) { %><tr><td colspan="7" class="text-center text-slate-500 py-6">কোনো request নেই।</td></tr><% } %>
      <% rows.forEach(function(r){ %>
        <tr>
          <td class="font-mono text-slate-500">#<%= r.id %></td>
          <td><a href="/users/<%= r.user_id %>" class="text-cyan-400 hover:underline"><%= r.username || r.user_id %></a></td>
          <td><%= r.category || '-' %></td>
          <td class="font-mono text-xs text-slate-300 max-w-xs truncate" title="<%= r.old_data %>"><%= r.old_data || '-' %></td>
          <td class="text-slate-400 text-xs"><%= r.reason || '-' %></td>
          <td class="text-slate-400 text-xs"><%= new Date(r.created_at).toLocaleString('en-GB') %></td>
          <td class="space-x-1">
            <% if (r.status === 'pending') { %>
              <form method="post" action="/replace/<%= r.id %>/collect" class="inline">
                <button class="bg-emerald-600 hover:bg-emerald-500 px-3 py-1 rounded text-xs">Collect</button>
              </form>
            <% } %>
            <form method="post" action="/replace/<%= r.id %>/delete" class="inline"
                  onsubmit="return confirm('Permanently delete?');">
              <button class="bg-rose-600 hover:bg-rose-500 px-3 py-1 rounded text-xs">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="mt-6 bg-slate-900/60 border border-slate-800 rounded-xl p-4 text-xs text-slate-400">
  <div class="font-semibold text-slate-300 mb-1">কীভাবে কাজ করে:</div>
  User bot এ replace command পাঠালে data এখানে এসে save হবে। আপনি data নিয়ে নিলে <b>Collect</b> চাপুন (history থাকবে),
  বা পুরোপুরি মুছে দিতে <b>Delete</b> চাপুন।
</div>

<%- include('partials/footer') %>
