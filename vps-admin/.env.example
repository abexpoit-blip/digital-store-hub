# --- VPS Admin Panel Config ---

# Path to your bot's SQLite DB
DB_PATH=../store.db

# Port for the admin panel
PORT=3000

# Session encryption (random long string)
SESSION_SECRET=change-this-to-a-very-long-random-string-please

# Master password (web admin login)
ADMIN_PASSWORD=changeMeNow123

# Telegram bot token (for /notice broadcast feature)
BOT_TOKEN=

# Shared secret with bot for signing public order download links (/o/:id/:sig)
# IMPORTANT: same value must be set in bot's environment / store.py
DOWNLOAD_SECRET=change-me-to-a-long-random-string

# Public base URL where this admin panel is reachable (no trailing slash)
# Used to render copy-able download links per order in admin user detail page.
PUBLIC_BASE_URL=https://your-domain.com
