# --- VPS Admin Panel Config ---

# Path to your bot's SQLite DB. Same folder as bot's store.db
DB_PATH=../store.db

# Port for the admin panel
PORT=3000

# Session encryption (যেকোনো random লম্বা string দিন)
SESSION_SECRET=change-this-to-a-very-long-random-string-please

# Master password (web admin login এর জন্য)
# এটা plain text। প্রথমবার server start হলে bcrypt hash বানাবে
ADMIN_PASSWORD=changeMeNow123
